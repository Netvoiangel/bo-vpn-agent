[Unit]
Description=BO/VPN Runner Daemon
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/timur/bo-vpn-agent
EnvironmentFile=/etc/bo-vpn-runner.env
ExecStart=/usr/bin/bash -lc 'cd /home/timur/bo-vpn-agent && exec /home/timur/bo-vpn-agent/.venv/bin/python -m bo_vpn_agent.runner_daemon_main --host 0.0.0.0 --port 8091'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
